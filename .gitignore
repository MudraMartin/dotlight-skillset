# -----------------------------------------------------------------------------
# Built artifacts
# -----------------------------------------------------------------------------
# Plugin archives — users install via marketplace or build locally
*.plugin

# Generic build output directories
/dist/
/build/
/out/

# -----------------------------------------------------------------------------
# Node.js
# Some skills (brainstorming/scripts/server.cjs, writing-skills/render-graphs.js)
# use Node. If anyone runs `npm install` or adds dependencies, these keep it clean.
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.yarn/
.pnp.*

# -----------------------------------------------------------------------------
# Python (future-proofing — writing-skills commonly grows Python helpers)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
env/

# -----------------------------------------------------------------------------
# Logs & temp files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.orig

# -----------------------------------------------------------------------------
# Secrets / local-only config
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.nvimrc.local

# -----------------------------------------------------------------------------
# OS junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Local scratch — author's private notes that shouldn't reach the public repo
# -----------------------------------------------------------------------------
/NOTES.md
/TODO.md
/scratch/
/private/
